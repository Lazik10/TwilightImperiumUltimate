    <div class="menu-item" @onmouseenter='() => OnMainMenuHoverStart("tools")' @onmouseleave='OnDesktopHoverEnd'>
        <div class="menu-container" @onmouseenter='() => OnMainMenuHoverStart("tools")' @onmouseleave='OnDesktopHoverEnd'>
            <a href="#" class='@GetDesktopMainMenuClass("tools")' @onclick='() => SelectMenu("tools")'>@Strings.Page_Tools</a>
            <div class="dropdown" @onmouseenter='() => OnMainMenuHoverStart("tools")' @onmouseleave='OnDesktopHoverEnd'>
                <a href="@Pages.GameTracker" target="_blank" class='@GetDesktopSubMenuClass("gametracker")' @onmouseenter='() => OnSubMenuHoverStart("tools", "gametracker")' @onclick='() => SelectSubMenuAndClose("tools", "gametracker")'>@Strings.Page_GameTracker</a>
                <a href="@Pages.ColorPicker" class='@GetDesktopSubMenuClass("colorpicker")' @onmouseenter='() => OnSubMenuHoverStart("tools", "colorpicker")' @onclick='() => SelectSubMenuAndClose("tools", "colorpicker")'>@Strings.Page_ColorPicker</a>
                <a href="@Pages.FactionDraft" class='@GetDesktopSubMenuClass("factiondraft")' @onmouseenter='() => OnSubMenuHoverStart("tools", "factiondraft")' @onclick='() => SelectSubMenuAndClose("tools", "factiondraft")'>@Strings.Page_FactionDraft</a>
                <a href="@Pages.MiltyDraft" class='@GetDesktopSubMenuClass("miltydraft")' @onmouseenter='() => OnSubMenuHoverStart("tools", "miltydraft")' @onclick='() => SelectSubMenuAndClose("tools", "miltydraft")'>@Strings.Page_MiltyDraft</a>
                <a href="@Pages.SliceGenerator" class='@GetDesktopSubMenuClass("slicegenerator")' @onmouseenter='() => OnSubMenuHoverStart("tools", "slicegenerator")' @onclick='() => SelectSubMenuAndClose("tools", "slicegenerator")'>@Strings.Page_SliceGenerator</a>
                <a href="@Pages.MapGenerator" class='@GetDesktopSubMenuClass("mapgenerator")' @onmouseenter='() => OnSubMenuHoverStart("tools", "mapgenerator")' @onclick='() => SelectSubMenuAndClose("tools", "mapgenerator")'>@Strings.Page_MapGenerator</a>
                <a href="@Pages.CardGenerator" class='@GetDesktopSubMenuClass("cardgenerator")' @onmouseenter='() => OnSubMenuHoverStart("tools", "cardgenerator")' @onclick='() => SelectSubMenuAndClose("tools", "cardgenerator")'>@Strings.Page_CardGenerator</a>
            </div>
        </div>
    </div>
    <div class="menu-item" @onmouseenter='() => OnMainMenuHoverStart("rules")' @onmouseleave='OnDesktopHoverEnd'>
        <div class="menu-container" @onmouseenter='() => OnMainMenuHoverStart("rules")' @onmouseleave='OnDesktopHoverEnd'>
            <a href="#" class='@GetDesktopMainMenuClass("rules")' @onclick='() => SelectMenu("rules")'>@Strings.Page_Rules</a>
            <div class="dropdown" @onmouseenter='() => OnMainMenuHoverStart("rules")' @onmouseleave='OnDesktopHoverEnd'>
                <a href="@Pages.Rules" class='@GetDesktopSubMenuClass("rulespage")' @onmouseenter='() => OnSubMenuHoverStart("rules", "rulespage")' @onclick='() => SelectSubMenuAndClose("rules", "rulespage")'>@Strings.Page_Rules</a>
                <a href="@Pages.Faq" class='@GetDesktopSubMenuClass("faq")' @onmouseenter='() => OnSubMenuHoverStart("rules", "faq")' @onclick='() => SelectSubMenuAndClose("rules", "faq")'>@Strings.Page_Faq</a>
                <a href="@Pages.Resources" class='@GetDesktopSubMenuClass("resources")' @onmouseenter='() => OnSubMenuHoverStart("rules", "resources")' @onclick='() => SelectSubMenuAndClose("rules", "resources")'>@Strings.Page_Resources</a>
