                <a href="@Pages.Cards" class='@GetDesktopSubMenuClass("cards")' @onmouseenter='() => OnSubMenuHoverStart("game", "cards")' @onclick='() => SelectSubMenuAndClose("game", "cards")'>@Strings.Page_Cards</a>
                <a href="@Pages.SystemTiles" class='@GetDesktopSubMenuClass("systemtiles")' @onmouseenter='() => OnSubMenuHoverStart("game", "systemtiles")' @onclick='() => SelectSubMenuAndClose("game", "systemtiles")'>@Strings.Page_SystemTiles</a>
                <a href="@Pages.Planets" class='@GetDesktopSubMenuClass("planets")' @onmouseenter='() => OnSubMenuHoverStart("game", "planets")' @onclick='() => SelectSubMenuAndClose("game", "planets")'>@Strings.Page_Planets</a>
            </div>
        </div>
    </div>
    <div class="menu-item" @onmouseenter='() => OnMainMenuHoverStart("community")' @onmouseleave='OnDesktopHoverEnd'>
        <div class="menu-container" @onmouseenter='() => OnMainMenuHoverStart("community")' @onmouseleave='OnDesktopHoverEnd'>
