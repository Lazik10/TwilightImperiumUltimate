                <a href="@Pages.TiglRegister" class='@GetDesktopSubMenuClass("tiglregister")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglregister")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglregister")'>@Strings.Page_TiglRegister</a>
                <a href="@Pages.TiglReportGame" class='@GetDesktopSubMenuClass("tiglreport")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglreport")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglreport")'>@Strings.Page_TiglReportGame</a>
                <a href="@Pages.TiglLeaderboard" class='@GetDesktopSubMenuClass("tiglleaderboard")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglleaderboard")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglleaderboard")'>@Strings.TiglMenu_Leaderboard</a>
                <a href="@Pages.TiglStatistics" class='@GetDesktopSubMenuClass("tiglstatistics")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglstatistics")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglstatistics")'>@Strings.TiglMenu_Statistics</a>
                <a href="@Pages.TiglPlayers" class='@GetDesktopSubMenuClass("tiglplayers")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglplayers")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglplayers")'>@Strings.TiglMenu_Players</a>
                <a href="@Pages.TiglGames" class='@GetDesktopSubMenuClass("tiglgames")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglgames")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglgames")'>@Strings.TiglMenu_GameReports</a>
                <a href="@Pages.TiglRankings" class='@GetDesktopSubMenuClass("tiglranks")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglranks")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglranks")'>@Strings.RankingsMenu_Ranks</a>
                <a href="@Pages.TiglLeaders" class='@GetDesktopSubMenuClass("tiglleaders")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglleaders")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglleaders")'>@Strings.RankingsMenu_Leaders</a>
                <a href="@Pages.TiglAchievements" class='@GetDesktopSubMenuClass("tiglachievements")' @onmouseenter='() => OnSubMenuHoverStart("tigl", "tiglachievements")' @onclick='() => SelectSubMenuAndClose("tigl", "tiglachievements")'>@Strings.RankingsMenu_Achievements</a>
