                <a href="@Pages.MapsArchive" class='@GetDesktopSubMenuClass("mapsarchive")' @onmouseenter='() => OnSubMenuHoverStart("community", "mapsarchive")' @onclick='() => SelectSubMenuAndClose("community", "mapsarchive")'>@Strings.Page_MapArchive</a>
                <a href="@Pages.SlicesArchive" class='@GetDesktopSubMenuClass("slicesarchive")' @onmouseenter='() => OnSubMenuHoverStart("community", "slicesarchive")' @onclick='() => SelectSubMenuAndClose("community", "slicesarchive")'>@Strings.Page_SlicesArchive</a>
                <a href="@Pages.Discord" class='@GetDesktopSubMenuClass("discord")' @onmouseenter='() => OnSubMenuHoverStart("community", "discord")' @onclick='() => SelectSubMenuAndClose("community", "discord")'>@Strings.Page_Discord</a>
                <a href="@Pages.Async" class='@GetDesktopSubMenuClass("async")' @onmouseenter='() => OnSubMenuHoverStart("community", "async")' @onclick='() => SelectSubMenuAndClose("community", "async")'>@Strings.Page_Async</a>
                <a href="@Pages.Websites" class='@GetDesktopSubMenuClass("websites")' @onmouseenter='() => OnSubMenuHoverStart("community", "websites")' @onclick='() => SelectSubMenuAndClose("community", "websites")'>@Strings.Page_OtherWebsites</a>
            </div>
        </div>
    </div>
    <div class="menu-item" @onmouseenter='() => OnMainMenuHoverStart("tigl")' @onmouseleave='OnDesktopHoverEnd'>
        <div class="menu-container" @onmouseenter='() => OnMainMenuHoverStart("tigl")' @onmouseleave='OnDesktopHoverEnd'>
            <a href="#" class='@GetDesktopMainMenuClass("tigl")' @onclick='() => SelectMenu("tigl")'>@Strings.Page_Tigl</a>
            <div class="dropdown" @onmouseenter='() => OnMainMenuHoverStart("tigl")' @onmouseleave='OnDesktopHoverEnd'>
