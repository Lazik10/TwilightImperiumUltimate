@using TwilightImperiumUltimate.Contracts.Enums
@using TwilightImperiumUltimate.Web.Components.Cards
@using TwilightImperiumUltimate.Web.Components.Shared.Layouts
@using TwilightImperiumUltimate.Web.Resources
@using TwilightImperiumUltimate.Web.Services.Path
@using TwilightImperiumUltimate.Web.Helpers.Resources;
@inherits FactionInfoComponentBase
@inject IPathProvider PathProvider

@* TODO: Create leader API endpoint for this or include them in faction response *@
@if (Faction.FactionName != FactionName.TheNomad 
    && Faction.FactionName != FactionName.TheCouncilKeleres 
    && Faction.FactionName != FactionName.TheGheminaRaiders)
{
    <div class="handel white shadow leaders-grid">
        @if (Faction.FactionName == FactionName.TheFirmamentTheObsidian)
        {
            <Label Text="The Firmament" CenterText="true" FontSize="24" CssClass="span-3" />
        }
        <FlexColumnCenteredContainer>
            <div>@Strings.Faction_Agent</div>
            <ResponsiveVerticalSpacer CustomHeight="10px" />
            <div>@Strings.Faction_AgentRequirement</div>
        </FlexColumnCenteredContainer>

        <FlexColumnCenteredContainer>
            <div>@Strings.Faction_Commander</div>
            <ResponsiveVerticalSpacer CustomHeight="10px" />
            <div>@(Faction.FactionName.GetFactionUIText(FactionResourceType.CommanderRequirement))</div>
        </FlexColumnCenteredContainer>

        <FlexColumnCenteredContainer>
            <div>@Strings.Faction_Hero</div>
            <ResponsiveVerticalSpacer CustomHeight="10px" />
            <div>@Strings.Faction_HeroRequirement</div>
        </FlexColumnCenteredContainer>

        <FlexColumnCenteredContainer>
            <div class="margin">
                <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.Agent))" />
            </div>
        </FlexColumnCenteredContainer>

        <FlexColumnCenteredContainer>
            <div class="margin">
                <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.Commander))" />
            </div>
        </FlexColumnCenteredContainer>

        <FlexColumnCenteredContainer>
            <div class="margin">
                <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.Hero))" />
            </div>
        </FlexColumnCenteredContainer>

        @if (Faction.FactionName == FactionName.TheFirmamentTheObsidian)
        {
            <Label Text="The Obsidian" CenterText="true" FontSize="24" CssClass="span-3" />

            <FlexColumnCenteredContainer>
                <div>@Strings.Faction_Agent</div>
                <ResponsiveVerticalSpacer CustomHeight="10px" />
                <div>@Strings.Faction_AgentRequirement</div>
            </FlexColumnCenteredContainer>

            <FlexColumnCenteredContainer>
                <div>@Strings.Faction_Commander</div>
                <ResponsiveVerticalSpacer CustomHeight="10px" />
                <div>@(Faction.FactionName.GetFactionUIText(FactionResourceType.CommanderRequirement))</div>
            </FlexColumnCenteredContainer>

            <FlexColumnCenteredContainer>
                <div>@Strings.Faction_Hero</div>
                <ResponsiveVerticalSpacer CustomHeight="10px" />
                <div>@Strings.Faction_HeroRequirement</div>
            </FlexColumnCenteredContainer>

            <FlexColumnCenteredContainer>
                <div class="margin">
                    <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.AgentObsidian))" />
                </div>
            </FlexColumnCenteredContainer>

            <FlexColumnCenteredContainer>
                <div class="margin">
                    <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.CommanderObsidian))" />
                </div>
            </FlexColumnCenteredContainer>

            <FlexColumnCenteredContainer>
                <div class="margin">
                    <HorizontalCard ImagePath="@(PathProvider.GetFactionComponenetTypeImagePath(Faction.FactionName.ToString(), ComponentType.HeroObsidian))" />
                </div>
            </FlexColumnCenteredContainer>
        }
    </div>
}


