@using TwilightImperiumUltimate.Web.Resources;

<div class="@GetContainerClass()">
    @if (!_isImageLoaded)
    {
        <div class="card-image-placeholder" aria-hidden="true"></div>
    }

    <img src="@CardImagePath"
         alt="@Name"
         class="card-image"
         style="@GetImageStyle()"
         loading="lazy"
         decoding="async"
         @onload="OnImageLoaded"
         @onerror="OnImageError">
</div>

