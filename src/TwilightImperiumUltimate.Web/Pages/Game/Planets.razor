@page "/game/planets"
@using System.Globalization
@using TwilightImperiumUltimate.Web.Components.Cards
@using TwilightImperiumUltimate.Web.Components.Galaxy
@using TwilightImperiumUltimate.Web.Components.Shared
@using TwilightImperiumUltimate.Web.Components.Shared.Layouts
@using TwilightImperiumUltimate.Web.Components.Shared.Text
@using TwilightImperiumUltimate.Web.Components.Shared.Controls
@using TwilightImperiumUltimate.Web.Helpers.Enums
@using TwilightImperiumUltimate.Web.Resources
@using Radzen

<PageTitle>@Strings.Page_Planets</PageTitle>

<Page>
    <ResponsiveText Text="@Strings.Page_Planets" CssClass="news-page-title handel white shadow" FontSize="2xl" CenterText="true" />
    <ResponsiveVerticalSpacer Size="2xl" />

    <div class="planets-filters-container">
        <div class="planets-filter-group">
            <div class="planets-filter-label handel white shadow">By Expansion:</div>
            <GameVersionFilterDropdown GameVersions="GetAvailableGameVersions()"
                                       SelectedGameVersion="@_selectedGameVersion"
                                       SelectedGameVersionChanged="OnGameVersionFilterChanged"
                                       CssClass="planets-filter-dropdown" />
        </div>

        <div class="planets-filter-group">
            <div class="planets-filter-label handel white shadow">By Trait:</div>
            <RadzenDropDown TValue="string"
                            Data="@GetPlanetFilterOptions()"
                            TextProperty="Label"
                            ValueProperty="Value"
                            Value="@_selectedPlanetFilter"
                            Change="OnPlanetFilterChanged"
                            class="planets-filter-dropdown"
                            Style="font-family: Handel, fallback, sans-serif" />
        </div>
    </div>

    <ResponsiveContainer Type="fluid" Padding="none">
        @foreach (var gameVersion in GetFilteredPlanets())
        {
            @if (!_selectedGameVersion.HasValue)
            {
                <ResponsiveText Text="@gameVersion.Key.GetDisplayName()" FontSize="xl" CenterText="true" CssClass="handel white shadow" />
            }

            <div class="planets-grid-shell">
                <ResponsiveGridContainer Columns="5" TabletColumns="3" MobileColumns="2" Width="100" Gap="0.625rem">
                    @foreach (var planet in gameVersion)
                    {
                        <div class="planet-item">
                            <div class="clickable" @onclick="@(() => ShowBigImage(planet, CultureInfo.CurrentCulture.Name))">
                                <PlanetCard Name="@planet.PlanetName.ToString()" />
                            </div>
                        </div>
                    }
                </ResponsiveGridContainer>
            </div>

            <ResponsiveVerticalSpacer Size="2xl" />
        }
    </ResponsiveContainer>

    @if (_showBigImage)
    {
        <div class="big-image-overlay" @onclick="HideBigImage">
            <div class="image-container">
                <img src="@_currentBigImageSrc" @onclick="HideBigImage" />
            </div>
            <div class="language-menu">
                <img class="language-flag @GetLanguageFlagClass(Strings.EnglishCulture)"
                        src="@(GetCultureIconPath(Strings.EnglishCulture))"
                        alt="English"
                        height="50"
                        @onclick="@(() => SetBigImageAddress(Strings.EnglishCulture))"
                        @onclick:stopPropagation="true" />
                <img class="language-flag @GetLanguageFlagClass(Strings.CzechCulture)"
                        src="@(GetCultureIconPath(Strings.CzechCulture))"
                        alt="Czech"
                        height="50"
                        @onclick="@(() => SetBigImageAddress(Strings.CzechCulture))"
                        @onclick:stopPropagation="true" />
            </div>
        </div>
    }
</Page>
